<?xml version="1.0"?>
<robot name="sensor_robot">

  <!-- ───── Links ───── -->

  <link name="base_link">
    <visual>
      <geometry><box size="0.3 0.2 0.1"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.3 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.008333" ixy="0" ixz="0"
                               iyy="0.016667" iyz="0"
                                              izz="0.021667"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.000554" ixy="0" ixz="0"
                               iyy="0.000900" iyz="0"
                                              izz="0.000554"/>
    </inertial>
  </link>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.000554" ixy="0" ixz="0"
                               iyy="0.000900" iyz="0"
                                              izz="0.000554"/>
    </inertial>
  </link>

  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000036" ixy="0" ixz="0"
                               iyy="0.000036" iyz="0"
                                              izz="0.000036"/>
    </inertial>
  </link>

  <!-- LiDAR mount -->
  <link name="laser_frame">
    <visual>
      <geometry><cylinder length="0.04" radius="0.05"/></geometry>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.04" radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000076" ixy="0" ixz="0"
                               iyy="0.000076" iyz="0"
                                              izz="0.000125"/>
    </inertial>
  </link>

  <!-- Depth camera mount -->
  <link name="depth_frame">
    <visual>
      <geometry><box size="0.04 0.09 0.03"/></geometry>
      <material name="green"><color rgba="0 0.6 0 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.04 0.09 0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000010" ixy="0" ixz="0"
                               iyy="0.000010" iyz="0"
                                              izz="0.000010"/>
    </inertial>
  </link>

  <!-- RGB camera mount -->
  <link name="camera_frame">
    <visual>
      <geometry><box size="0.04 0.06 0.04"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.04 0.06 0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000010" ixy="0" ixz="0"
                               iyy="0.000010" iyz="0"
                                              izz="0.000010"/>
    </inertial>
  </link>

  <!-- ───── Joints ───── -->

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="0.05 0.125 -0.05" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  effort="10" velocity="10"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0.05 -0.125 -0.05" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  effort="10" velocity="10"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_wheel"/>
    <origin xyz="-0.1 0 -0.08" rpy="0 0 0"/>
  </joint>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_frame"/>
    <origin xyz="0.0 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- Camera mounted at front, slightly above LiDAR height -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_frame"/>
    <origin xyz="0.16 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- Depth camera mounted above RGB camera -->
  <joint name="depth_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="depth_frame"/>
    <origin xyz="0.16 0 0.11" rpy="0 0 0"/>
  </joint>

  <!-- ───── Gazebo Fortress ───── -->

  <!-- High friction drive wheels -->
  <gazebo reference="left_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="right_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <!-- Frictionless caster -->
  <gazebo reference="caster_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>0</mu><mu2>0</mu2></ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <!-- ───── Diff drive plugin ───── -->

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.25</wheel_separation>
      <wheel_radius>0.06</wheel_radius>
      <odom_publish_frequency>10</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <max_linear_acceleration>1.0</max_linear_acceleration>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher"/>
  </gazebo>

  <!-- ───── LiDAR sensor (2D) ───── -->

  <gazebo reference="laser_frame">
    <sensor name="laser" type="gpu_lidar">
      <gz_frame_id>laser_frame</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.5</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ───── LiDAR sensor (3D) ───── -->
  <!-- <gazebo reference="laser_frame">
    <sensor name="lidar_3d" type="gpu_lidar">
      <gz_frame_id>laser_frame</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>lidar</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>180</samples>        
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle> 
            <max_angle>3.14159</max_angle>  
          </horizontal>
          <vertical>
            <samples>16</samples>           
            <resolution>1</resolution>
            <min_angle>-0.26180</min_angle>
            <max_angle>0.26180</max_angle> 
          </vertical>
        </scan>
        <range>
          <min>0.5</min>
          <max>100.0</max>
          <resolution>0.03</resolution>    
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.008</stddev>           
        </noise>
      </lidar>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo> -->

  <!-- ───── RGB camera sensor ───── -->

  <gazebo reference="camera_frame">
    <sensor name="rgb_camera" type="camera">
      <gz_frame_id>camera_frame</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>camera/image_raw</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.0472</horizontal_fov>  
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ───── Depth camera sensor (RGBD) ───── -->

  <!-- <gazebo reference="depth_frame">
    <sensor name="depth_camera" type="rgbd_camera">
      <gz_frame_id>depth_frame</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>depth_camera</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.0472</horizontal_fov> 
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </camera>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo> -->

</robot>